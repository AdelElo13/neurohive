{
  "name": "neurohive",
  "version": "1.0.0",
  "description": "Multi-agent memory intelligence layer — shared knowledge, expertise tracking, and conflict detection for AI agent teams",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "neurohive": "bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
